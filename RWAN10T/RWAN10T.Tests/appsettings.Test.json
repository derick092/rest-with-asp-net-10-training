{
  "Cors": {
    "Origins": [
      "http://localhost:3000"
    ]
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning",
        "RWAN10T": "Debug" // Set RWAN10T namespace to Debug level for more detailed logging during development
      }
    },
    "WriteTo": [
      { "Name": "Console"}
    ]
  },
  "AllowedHosts": "*"
}
