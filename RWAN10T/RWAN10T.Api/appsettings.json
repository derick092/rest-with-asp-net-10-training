{
  "MSSQLServerConnection": {
    "MSSQLServerConnectionString": "Data Source=localhost,1433;Initial Catalog=RWAN10T;User Id=sa;Password=@Admin123;TrustServerCertificate=true;"
  },
  "Cors": {
    "Origins": [
      "http://localhost:3000"
    ]
  },
  "Email": {
    "Subject": "Default subject",
    "Message": "This is a default message.",
    "Host": "smtp.gmail.com",
    "Port": 587,
    "Username": "${EMAIL_USERNAME}",
    "Password": "${EMAIL_PASSWORD}",
    "Properties": {
      "SmtpAuth": true,
      "StartTlsEnable": true,
      "StartTlsRequired": true
    },
    "Ssl": true
  },
  "TokenConfigurations": {
    "Audience": "ExampleAudience",
    "Issuer": "ExampleIssuer",
    "Secret": "THIS_IS_A_SUPER_SUPER_SUPER_SECRET_KEY",
    "Minutes": 60,
    "DaysToExpiry": 7
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning",
        "RWAN10T": "Debug" // Set RWAN10T namespace to Debug level for more detailed logging during development
      }
    },
    "WriteTo": [
      { "Name": "Console"}
    ]
  },
  "AllowedHosts": "*"
}
